{
  "name": "ragstudy",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@clerk/shared", "@openrouter/sdk"]
  },
  "scripts": {
    "all": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "start": "pnpm --filter frontend start",
    "lint": "pnpm --filter frontend lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
